# Mongo
DATABASE_URL=mongodb://vgi:vgi2026@3.110.77.148:27017/vgi_skill_lab?authSource=admin&replicaSet=rs0&directConnection=true
DATABASE_NAME=vgi_skill_lab
KNOWLEDGE_BASE_COLLECTION=knowledge_base
QUESTION_BANK_COLLECTION=question_bank

# LLM provider: "anthropic" or "openai" — controls question generation only
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
LLM_MODEL_NAME=gpt-4o-mini

# OpenAI API key — ALWAYS required regardless of LLM_PROVIDER above, because
# embeddings (topic matching + KB retrieval ranking) always use OpenAI.
OPENAI_API_KEY=

# Embeddings — OpenAI, used live on every request that touches the knowledge base
# (topic matching + KB retrieval ranking), and during seeding for duplicate detection.
# Independent of LLM_PROVIDER above — always OpenAI regardless of which provider generates.
EMBEDDING_MODEL=text-embedding-3-small

# Topic matching
TOPIC_MATCH_THRESHOLD=0.80

# Seeding targets
SEED_QUESTIONS_PER_TOPIC_PER_DIFFICULTY=50
SEED_DUPLICATE_THRESHOLD=0.95

# App
APP_ENV=development
LOG_LEVEL=INFO
